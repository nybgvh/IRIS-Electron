# IRIS dev environment.
# Copy this file to `.env` (gitignored) and fill in the values you need.
#
# Loaded ONLY in unpackaged builds (`npm start`). Packaged builds never read
# .env — they receive their configuration through the host environment, the
# same way a production web service does. End users never see any of this;
# the only credentials they touch are their email + password.

# -----------------------------------------------------------------------------
# Backend target
# -----------------------------------------------------------------------------
# Where the renderer should talk to. In Phase 0 this is in-process (Electron
# main is the "server"), so the value is unused. Once the web service exists,
# point this at it for staging / prod runs:
#   IRIS_SERVER_URL=https://iris-staging.nybg.org/api
IRIS_SERVER_URL=

# -----------------------------------------------------------------------------
# Storage root for uploaded files (specimen images, PDFs, notebooks).
# Leave blank to use the default: <userData>/storage  (e.g. on macOS
# ~/Library/Application Support/iris/storage). Set to an absolute path to put
# uploads somewhere shared (a NAS, a Dropbox folder, etc.):
#   IRIS_STORAGE_ROOT=/Users/you/Dropbox/iris-uploads
IRIS_STORAGE_ROOT=

# -----------------------------------------------------------------------------
# Database. Leave blank to use the default: <userData>/iris.sqlite.
# When we add the web service, this becomes a Postgres URL.
# -----------------------------------------------------------------------------
IRIS_DATABASE_URL=

# -----------------------------------------------------------------------------
# Third-party API keys — DEV ONLY.
#
# The shipped Electron app does not contain any of these. In production, the
# renderer makes an authenticated call to the IRIS server which holds the
# keys server-side. These entries exist so individual devs can run inference
# locally during development without standing up the full server.
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
BHL_API_KEY=
GBIF_API_USER=
GBIF_API_PASSWORD=

# -----------------------------------------------------------------------------
# VoucherVisionGO submission pipeline.
#
# When VV_API_BASE_URL and VV_API_KEY are both set the in-process queue boots
# and every newly-uploaded image / PDF / notebook source is submitted to the
# /process endpoint automatically. Results are written to disk and tracked in
# the `vouchervision_records` table.
#
# Users never set these — the server (this Electron app today, a real backend
# later) holds them. The shipped Electron build ships without secrets; in dev
# we read them from .env so individual contributors can exercise the flow.
# -----------------------------------------------------------------------------

# Required: where the VoucherVisionGO server lives and how to authenticate.
# Short keys go in X-API-Key; JWTs (long string with dots) use Authorization: Bearer.
VV_API_BASE_URL=
VV_API_KEY=

# Endpoint path on the server. Defaults to /process. Override only if your
# deployment exposes a different sync route.
# VV_ENDPOINT=/process

# Inference knobs — match the flags VoucherVisionGO-client/VoucherVision.py exposes.
# `engines` is a comma-separated list (rendered as repeated multipart fields).
VV_PROMPT=SLTPvM_full.yaml
VV_ENGINES=gemini-3.1-flash-lite
VV_LLM_MODEL=gemini-3.1-flash-lite

# Booleans default false unless noted.
VV_OCR_ONLY=false
VV_NOTEBOOK_MODE=false
VV_SKIP_LABEL_COLLAGE=false
VV_INCLUDE_WFO=true
VV_INCLUDE_COP90=true            

# Vertex AI billing (OPTIONAL). Bill VVGO's Gemini inference to your own Google
# Cloud project instead of the shared VVGO account — the same `vertex_project`
# auth method used in examples/run_vv.ipynb. Leave blank to use the default VVGO
# billing. The project must first be linked to your VVGO account (API Settings
# at https://leafmachine.org/vouchervisiongo/). Only forwarded when non-empty.
VV_VERTEX_PROJECT=
VV_VERTEX_REGION=global

# Queue and worker shape.
VV_CONCURRENCY=4                 # how many record jobs run at once
VV_PAGE_CONCURRENCY=16            # parallel page submissions within one PDF
VV_PDF_DPI=150                   # rasterisation DPI for PDF pages
# PDF / notebook pages are text documents with no single specimen label, so the
# server's collage step 500s. Submit those pages OCR-only with the collage
# skipped — they return OCR text (no formatted_json). PDF/notebook pages only;
# single specimen images are unaffected.
VV_PDF_OCR_ONLY=true
VV_PDF_SKIP_LABEL_COLLAGE=true
VV_TIMEOUT_MS=300000             # per-submit timeout (5 minutes)
VV_MAX_RETRIES=2                 # retries on network / 5xx errors
VV_TICK_MS=2000                  # worker wake interval
